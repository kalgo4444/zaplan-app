{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": true,
	"mcp": {
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true,
			"headers": {
				"CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
			}
		},
		"playwright": {
			"type": "local",
			"command": ["npx", "-y", "@playwright/@latest", "--headless"],
			"enabled": true
		}
	},
	"permission": {
		"webfetch": "allow",
		"edit": "allow",
		"skill": {
			"*": "allow"
		},
		"bash": {
			"*": "ask",
			"ls *": "allow",
			"git *": "allow",
			"npm *": "allow",
			"bun *": "allow",
			"rm *": "deny",
			"sudo *": "deny"
		}
	},
	"instructions": ["AGENTS.md", ".opencode/USER.md", ".opencode/rules/*.md"]
}
